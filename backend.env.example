# Backend (Railway) — set these in Railway project variables

# Required for Run Scout (Google Places API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Required for syncing scout results to Supabase
# For MixedMakerShop integration, this must be:
# https://zwdsnwvuhaesbllzbfmt.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
ALLOWED_ORIGINS=https://YOUR_VERCEL_PROJECT.vercel.app

# Railway sets PORT automatically; optional for local
# PORT=8760

# Daily automatic morning scout
ENABLE_SCHEDULED_SCOUT=true
SCHEDULED_SCOUT_HOUR=7
# Use "local" to run at server local time, or set an IANA timezone (e.g. America/Chicago)
SCHEDULED_SCOUT_TIMEZONE=local
